{
  "name": "@agent-runner/studio",
  "version": "0.1.0",
  "description": "Development studio for agent-runner \u2014 visual agent editor, playground, tool catalog, and eval dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && vite build",
    "build:server": "tsup",
    "build:ui": "vite build",
    "dev": "tsup --watch",
    "dev:ui": "vite --config vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup && vite build"
  },
  "keywords": [
    "ai",
    "agents",
    "studio",
    "development",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aparryopenclaw/agent-runner.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/aparryopenclaw/agent-runner#readme",
  "author": "Aaron Bidworthy",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "peerDependencies": {
    "agent-runner": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "agent-runner": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
